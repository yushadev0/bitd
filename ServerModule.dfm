  CustomCSS.Strings = (
    '.made-with-love {'
    '  text-align: center;'
    '  padding: 15px 10px;'
    '  font-family: '#39'Press Start 2P'#39', cursive;'
    '  font-size: 0.55rem;'
    '  color: rgba(255,255,255,0.6);'
    '  letter-spacing: 1px;'
    '  line-height: 1.8;'
    '}'
    ''
    '.made-with-love .heart i {'
    '  font-size: 0.8rem;                '
    '  color: #ff2a6d;                   '
    '  filter:'
    '    drop-shadow(0 0 6px #ff2a6d)'
    '    drop-shadow(0 0 12px #ff2a6d)'
    '    drop-shadow(0 0 20px rgba(255,42,109,0.8));'
    '  animation: heart-pulse 1.4s infinite ease-in-out;'
    '}'
    ''
    '@keyframes heart-pulse {'
    '  0%   { transform: scale(1);   }'
    '  50%  { transform: scale(1.25); }'
    '  100% { transform: scale(1);   }'
    '}'
    ''
    '.made-with-love .author {'
    '  color: var(--neon-blue);'
    '  text-shadow: 0 0 6px var(--neon-blue);'
    '}'
    ''
    '.made-with-love .author a {'
    
      '  color: inherit;              /* mevcut neon-blue rengi korur *' +
      '/'
    '  text-decoration: none;       /* alt '#231'izgi yok */'
    '  transition: all 0.3s ease;'
    '}'
    ''
    '.made-with-love .author a:hover {'
    '  color: var(--neon-blue);'
    '  text-shadow:'
    '    0 0 6px var(--neon-blue),'
    '    0 0 12px var(--neon-blue),'
    '    0 0 20px rgba(5,217,232,0.8);'
    '}')
